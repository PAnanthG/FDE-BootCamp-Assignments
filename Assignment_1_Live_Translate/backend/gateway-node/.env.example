# Node gateway config — copy to `.env`
PORT=8787
AI_SERVICE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Added by this build (not in the original scaffold)
# ---------------------------------------------------------------------------

# Timeout for gateway -> AI service calls, in ms.
# Deliberately generous: /translate/batch translates sequentially upstream, so a
# large uncached batch legitimately takes tens of seconds. This exists to catch a
# genuinely hung AI service, not to police slow-but-working requests.
AI_TIMEOUT_MS=40000
