# Python AI service config — copy to `.env`
# Use the key for whichever provider you implement in lib/llm.py
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENAI_API_KEY=...
# OPENROUTER_API_KEY=...   # route through OpenRouter to keep the provider swappable

MODEL=claude-sonnet-4-6
TRANSLATION_DB_PATH=translations.db

# ---------------------------------------------------------------------------
# Added by this build (not in the original scaffold)
# ---------------------------------------------------------------------------

# Output language override.
# This build translates to DUTCH, whatever `target` the caller sends. The widget
# hardcodes target:"es-MX" and widget/ must not be edited, so the override lives
# here instead. Set FORCE_TARGET="" to honour the caller's `target` instead
# (es-MX / es-ES / pt-BR) — that's the language-picker stretch goal.
#
# Safe to change: cache entries are keyed by the EFFECTIVE language, so flipping
# this produces clean misses, never a wrong-language cache hit.
FORCE_TARGET=nl

# Max entries in the in-memory cache tier; LRU-evicted beyond this.
# Evicted entries still live in SQLite, so eviction costs milliseconds — never
# an LLM call.
CACHE_MEM_MAX=5000
